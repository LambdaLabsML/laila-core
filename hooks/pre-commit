#!/usr/bin/env bash
# Pre-commit hook: reject staged files that contain hardcoded secrets.
# Installed automatically by `make init` / conftest.py.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ── Files that are allowed to match (this hook, docs about secrets, etc.) ──
ALLOW_LIST=(
    "hooks/pre-commit"
    "vault/agent/laila_args_exemptions.md"
)

is_allowed() {
    local file="$1"
    for allowed in "${ALLOW_LIST[@]}"; do
        [[ "$file" == "$allowed" ]] && return 0
    done
    return 1
}

# ── Secret patterns (extended regex, one per line) ──
PATTERNS=(
    'AKIA[0-9A-Z]{16}'                                         # AWS access key ID
    '-----BEGIN[ A-Z]*PRIVATE KEY-----'                         # PEM private key
    'hf_[a-zA-Z0-9]{20,}'                                      # HuggingFace token
    'ghp_[a-zA-Z0-9]{30,}'                                      # GitHub PAT
    'gho_[a-zA-Z0-9]{30,}'                                      # GitHub OAuth
    'github_pat_[a-zA-Z0-9_]{30,}'                              # GitHub fine-grained PAT
    'sk-[a-zA-Z0-9]{20,}'                                      # OpenAI / Stripe secret key
    'xox[bpoas]-[a-zA-Z0-9\-]{10,}'                            # Slack token
    'AccountKey=[A-Za-z0-9+/=]{20,}'                            # Azure connection string key
    'DefaultEndpointsProtocol=https;Account'                    # Azure connection string
)

# Build a single combined regex
COMBINED=""
for p in "${PATTERNS[@]}"; do
    [[ -n "$COMBINED" ]] && COMBINED+="|"
    COMBINED+="($p)"
done

# ── Scan staged file contents ──
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

FOUND=0

while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    is_allowed "$file" && continue
    # Skip binary files
    if file --mime "$file" 2>/dev/null | grep -q "binary"; then
        continue
    fi

    MATCHES=$(git diff --cached -U0 -- "$file" \
        | grep -E '^\+' \
        | grep -v '^[+][+][+]' \
        | grep -Eni "$COMBINED" 2>/dev/null || true)

    if [[ -n "$MATCHES" ]]; then
        if [[ "$FOUND" -eq 0 ]]; then
            echo ""
            echo -e "${RED}✗ SECRET DETECTED — commit blocked${NC}"
            echo -e "${YELLOW}  The following staged additions contain patterns that look like secrets:${NC}"
            echo ""
        fi
        FOUND=1
        echo -e "  ${RED}$file${NC}"
        while IFS= read -r line; do
            echo "    $line"
        done <<< "$MATCHES"
        echo ""
    fi
done <<< "$STAGED_FILES"

if [[ "$FOUND" -ne 0 ]]; then
    echo -e "${YELLOW}  If this is a false positive, add the file to ALLOW_LIST in hooks/pre-commit.${NC}"
    echo ""
    exit 1
fi
